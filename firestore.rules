rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Settings (pricing, translations) — public read, admin write
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Blog posts — public read, admin write
    match /blog_posts/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Portfolio — public read, admin write
    match /portfolio/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact form submissions — anyone can submit, only admin can read/delete
    match /submissions/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
